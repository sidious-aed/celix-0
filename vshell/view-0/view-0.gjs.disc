let html = "";
let sig = [];
let bsig = []
let jpids_1 = [];
let psite = 0;
let pulse = function() {
	let naof_jpids_1 = jpids_1.length;
	let jsite = 0;
	while(true) {
		if(jsite == naof_jpids_1) {
			break;
		}
		let jpid = jpids_1[jsite];
		//GLib.source_remove(jpid);
		jsite += 1;
	}
	jpids_1 = [];
	webView.run_javascript('document.documentElement.outerHTML;', null, (view, result) => {
		let update_intreaguing_cache = function() {
			//log("i sim. from catecombage find.");
			let jsResult = view.run_javascript_finish(result);
			let jsValue = jsResult.get_js_value();
			html = jsValue.to_string();
		}
		update_intreaguing_cache();
	});
	sig = clerk.simple_sig(html);
	//log("psite | " + psite);
	//log("sig | " + sig);
	let launch = clerk.vecter_compair(sig, bsig);
	//log("launch | " + launch);
	bsig = sig;
	if((psite == 0) || launch) {
		/*
		*/
		let jpid = GLib.timeout_add(GLib.PRIORITY_DEFAULT, 127, for_an_after_pause_times);
		jpids_0.push(jpid);
	}
	//log("i sim.");
	//log("html | " + html);
	let jpid = GLib.timeout_add(GLib.PRIORITY_DEFAULT, 527, pulse);
	jpids_1.push(jpid);
	psite += 1;
	return GLib.SOURCE_REMOVE;
}
let jpid = GLib.timeout_add(GLib.PRIORITY_DEFAULT, 3027, pulse);
jpids_1.push(jpid);


file = Gio.File.new_for_path("view-0.css");
[ok, contents] = file.load_contents(null);
let userStyleSheet = new WebKit2.UserStyleSheet(
    "" + contents,
    WebKit2.UserContentInjectedFrames.ALL_FRAMES,
    WebKit2.UserStyleLevel.USER,
    null,
    null
);
let manager = webView.get_user_content_manager();
manager.add_style_sheet(userStyleSheet);

// key response
window.connect("key-press-event", (widget, event) => {
    // Get key value
    let [, keyval] = event.get_keyval();

    // Check for specific key (e.g., Escape)
    if (keyval == Gdk.KEY_Escape) {
        log("weary ... and [(mint)|(meant)] warm maybe even.");
        window.close();
        return true; // Event handled
    }

    log(`Key pressed: ${keyval}`);
    return false; // Propagate event
});

// load for clerical reasons.
file = Gio.File.new_for_path("view-0.js");
[ok, contents] = file.load_contents(null);
//log("" + contents);

