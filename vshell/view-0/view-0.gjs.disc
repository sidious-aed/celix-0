window.get_style_context().add_class("generalp");
window.set_default_size(800, 600);
window.connect("destroy", Gtk.main_quit);

let webView = new WebKit2.WebView();
window.add(webView);
// Load HTML content
webView.load_html("" + hip_file, null);

