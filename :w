##########################################################################################################
# write-key-value
##########################################################################################################
aqs data-key
aqs data-key-site
aqs data-value
aqs data-value-site
aqs at-site

mq hash-meta-site r8
cmp 0 r8
st jne is-first-hash-element-com
	mq r8 at-site
	st jmp is-not-first-hash-element-com
s is-first-hash-element-com
	lq hash-data-name rsi
	lq data-key rdi
	mq hash-data-site rbx
	sub 1 rbx
	mq equations r12
	mq views r13
	mq vects r11
	addc vects gvr r11
	dct r11

	ent rdata-value data-value
	lent rdata-value rsi
	mq data-value rdi
	mov 10 rbx
	mq equations rdx
	mq views r11
	addc views wtlrfvn r11
	dct r11

	ent rdata-value data-value
	lent rdata-value rsi
	mq data-value rdi
	mov 10 rbx
	mq equations rdx
	mq views r11
	addc views wtlrfvn r11
	dct r11

	mq data-value r8
	mq data-value-site r9
	mq r9 r8
	mq r8 at-site
s is-not-first-hash-element-com

# open-write
mov 1f8 rdx
mov 41 rsi
mq hash-name rdi
mov 2 rax
sys
mq rax file
# lseek
mq file rdi
nao rsi
nao rdx
mov 8 rax
sys
# write
mq file rdi
mq key rsi
mq key-site rdx
mov 1 rax
sys
# write
mq file rdi
mq value rsi
mq value-site rdx
mov 1 rax
sys
# close
mq file rdi
mov 3 rax
sys

##########################################################################################################
# write-meta
##########################################################################################################
aqs rnaof-meta-esecs
mov 10 r8
mq r8 rnaof-meta-esecs
aqs meta-rsite
aqs meta-at
aqs rmeta-data-site
aqs rmeta-naof-datas

mq is-anew r8
cmp 1 r8
st jne is-anew-com
	mq hash-data-site r8
	mq r8 rmeta-data-site
	mov 1 r8
	mq r8 rmeta-naof-datas

	lq hash-meta-name rdi
	lq rmeta-data-site rsi
	mq equations r12
	mq views r13
	mq vects r11
	addc vects av r11
	dct r11

st jmp is-not-anew-com
s is-anew-com
	mq hash-meta-site rbx
	sub 1 rbx
	mq rbx meta-rsite
	factq rnaof-meta-esecs rbx
	mq rbx meta-at

	lq hash-data-name rsi
	lq rmeta-data-site rdi
	mq meta-rsite rbx
	mq equations r12
	mq views r13
	mq vects r11
	addc vects gvr r11
	dct r11
	mq rmeta-data-site r8
	add 1 r8
	mq r8 rmeta-data-site

	# open-write
	mov 1f8 rdx
	mov 41 rsi
	lq hash-meta-name rdi
	mov 2 rax
	sys
	mq rax file

	# lseek
	mq file rdi
	mq meta-at rsi
	nao rdx
	mov 8 rax
	sys

	# write
	mq file rdi
	mov 8 rdx
	lq rmeta-data-site
	mov 1 rax
	sys

	# close
	mq file rdi
	mov 3 rax
	sys
s is-not-anew-com

##########################################################################################################
